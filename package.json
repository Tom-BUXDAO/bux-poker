{
  "name": "bux-poker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"cd web && npm run dev\" \"cd src/bot && ts-node discord.ts\"",
    "build": "cd web && npm install && npm run build",
    "start:web": "cd web && npm run start",
    "start:bot": "cd src && ts-node bot/discord.ts",
    "start": "ts-node src/bot/discord.ts"
  },
  "keywords": [
    "poker",
    "discord",
    "tournament",
    "game"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "@types/node": "^20.11.25",
    "@types/pg": "^8.11.2",
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.7",
    "pg": "^8.11.3",
    "typescript": "^5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2"
  }
}
